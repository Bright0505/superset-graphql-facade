# ============================================================
# 此檔僅供本機開發使用
# CI/CD 部署時 SUPERSET_URL 與 REDIS_URL 由 .gitlab-ci.yml 動態注入,
# 指向同 docker network 內的 gt-war-room-superset-internal[-dev]
# 與 gt-war-room-redis[-dev],無須在 DEV_API/PROD_API 變數內設定
# ============================================================

# --- Server ---
PORT=4000
LOG_LEVEL=info
NODE_ENV=development

# --- Superset upstream ---
# 本機開發:直接連 dev/prd 外部 Superset(受 DASHBOARD_RBAC 過濾)
# 開發用:https://rep-lab.greattree.com.tw
# 正式用:https://rep.greattree.com.tw
SUPERSET_URL=https://rep-lab.greattree.com.tw
SUPERSET_USERNAME=api
SUPERSET_PASSWORD=

# --- Redis(Phase 2 啟用)---
REDIS_URL=redis://localhost:6379

# --- 客戶端認證(API Key,以逗號分隔)---
# 範例:API_KEYS=internal-frontend:abcd1234,partner-x:efgh5678
API_KEYS=

# --- Rate limit ---
# 每個 API key 每分鐘最大請求數，0 = 停用
RATE_LIMIT_RPM=60
