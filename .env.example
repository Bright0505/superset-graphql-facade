# --- Server ---
PORT=4000
LOG_LEVEL=info
NODE_ENV=development

# --- Superset upstream ---
# 開發用:https://rep-lab.greattree.com.tw
# 正式用:https://rep.greattree.com.tw
SUPERSET_URL=https://rep-lab.greattree.com.tw
SUPERSET_USERNAME=api
SUPERSET_PASSWORD=

# --- Redis(Phase 2 啟用)---
REDIS_URL=redis://localhost:6379

# --- 客戶端認證(API Key,以逗號分隔)---
# 範例:API_KEYS=internal-frontend:abcd1234,partner-x:efgh5678
API_KEYS=
